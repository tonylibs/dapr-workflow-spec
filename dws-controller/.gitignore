#Maven
target/

# cdk8s imports are generated at build time into target/ (see pom.xml).
# These are the paths a raw `npx cdk8s-cli import` would write to if run from
# the project root; keep them out of git so a stray manual run isn't committed.
/src/main/java/imports/
/src/main/resources/imports/
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
release.properties
.flattened-pom.xml

